@model List<Note>
@{
    ViewData["Title"] = "Top Rated Notes";
    var category = ViewBag.Category as string ?? "";
}

<h1 class="h2 mb-4"><i class="bi bi-star-fill text-warning me-2"></i>Top Rated Notes</h1>

<div class="row mb-4">
    <div class="col-md-6">
        <form method="get" asp-action="TopRated" class="d-flex gap-2">
            <input type="text" name="category" value="@category" class="form-control" placeholder="Filter by category..." />
            <button type="submit" class="btn btn-outline-secondary">Filter</button>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No rated notes yet.</div>
}
else
{
    <div class="list-group">
        @for (int i = 0; i < Model.Count; i++)
        {
            var note = Model[i];
            <a href="/Notes/Details/@note.Id" class="list-group-item list-group-item-action">
                <div class="d-flex w-100 justify-content-between align-items-center">
                    <div>
                        <span class="badge bg-secondary me-2">#@(i + 1)</span>
                        <strong>@Html.Raw(note.Title)</strong>
                        <small class="text-muted ms-2">by @note.Owner?.Username</small>
                    </div>
                    <div>
                        <span class="badge bg-warning text-dark fs-6">
                            <i class="bi bi-star-fill me-1"></i>@note.AverageRating.ToString("F1")
                        </span>
                        <small class="text-muted ms-2">@note.Ratings.Count rating(s)</small>
                    </div>
                </div>
                <p class="mb-1 mt-1 text-muted small">
                    @Html.Raw(note.Content.Length > 200 ? note.Content.Substring(0, 200) + "..." : note.Content)
                </p>
            </a>
        }
    </div>
}
