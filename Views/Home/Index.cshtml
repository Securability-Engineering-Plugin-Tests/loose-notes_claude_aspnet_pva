@model List<Note>
@{
    ViewData["Title"] = "Home";
}

<div class="row mb-4">
    <div class="col">
        <h1 class="display-5 fw-bold">Welcome to Loose Notes</h1>
        <p class="lead text-muted">Share your thoughts, discover ideas, and connect with others.</p>
        @if (User.Identity?.IsAuthenticated != true)
        {
            <a href="/Account/Register" class="btn btn-primary me-2">Get Started</a>
            <a href="/Account/Login" class="btn btn-outline-secondary">Login</a>
        }
        else
        {
            <a href="/Notes/Create" class="btn btn-primary me-2"><i class="bi bi-plus-circle me-1"></i>New Note</a>
            <a href="/Notes" class="btn btn-outline-secondary">My Notes</a>
        }
    </div>
</div>

<div class="row mb-3">
    <div class="col">
        <form method="get" action="/Notes/Search" class="d-flex gap-2">
            <input type="text" name="q" class="form-control" placeholder="Search public notes..." />
            <button type="submit" class="btn btn-outline-primary"><i class="bi bi-search"></i></button>
        </form>
    </div>
</div>

<h2 class="h4 mb-3">Recent Public Notes</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">No public notes yet. Be the first to share!</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var note in Model.Take(9))
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">
                            <a href="/Notes/Details/@note.Id" class="text-decoration-none">@note.Title</a>
                        </h5>
                        <p class="card-text text-muted small">
                            @(note.Content.Length > 120 ? note.Content.Substring(0, 120) + "..." : note.Content)
                        </p>
                    </div>
                    <div class="card-footer d-flex justify-content-between align-items-center">
                        <small class="text-muted">by @note.Owner?.Username</small>
                        @if (note.Ratings.Count > 0)
                        {
                            <span class="badge bg-warning text-dark">
                                <i class="bi bi-star-fill"></i> @note.AverageRating.ToString("F1")
                                <span class="text-dark opacity-75">(@note.Ratings.Count)</span>
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">No ratings</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
