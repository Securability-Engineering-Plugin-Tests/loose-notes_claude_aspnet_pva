@{
    ViewData["Title"] = "Import XML";
}

<h1 class="h2 mb-4"><i class="bi bi-file-earmark-code me-2"></i>Import Notes via XML</h1>

<div class="card shadow">
    <div class="card-body p-4">
        <p class="text-muted">Paste XML data to bulk-import notes. Format:</p>
        <pre class="bg-light p-3 rounded small">&lt;notes&gt;
  &lt;note&gt;
    &lt;title&gt;My Note Title&lt;/title&gt;
    &lt;content&gt;Note content here&lt;/content&gt;
  &lt;/note&gt;
&lt;/notes&gt;</pre>
        <form method="post" action="/Admin/ImportXml">
            <div class="mb-3">
                <label class="form-label">XML Data</label>
                <textarea name="xmlData" class="form-control font-monospace" rows="12"></textarea>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Import</button>
                <a href="/Admin" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
