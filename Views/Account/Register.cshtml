@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-body p-4">
                <h2 class="card-title mb-4">Create Account</h2>
                <form method="post" asp-action="Register">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewContext.ModelState.IsValid ? "none" : "block")"></div>

                    <div class="mb-3">
                        <label asp-for="Username" class="form-label"></label>
                        <input asp-for="Username" class="form-control" autocomplete="username" />
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" type="email" class="form-control" autocomplete="email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" type="password" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label"></label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <hr />
                    <h6 class="mb-3">Account Recovery</h6>

                    <div class="mb-3">
                        <label asp-for="SecurityQuestion" class="form-label"></label>
                        <select asp-for="SecurityQuestion" class="form-select">
                            <option value="">-- Choose a question --</option>
                            <option>What is the name of your first pet?</option>
                            <option>What city were you born in?</option>
                            <option>What was the name of your elementary school?</option>
                            <option>What is your mother's maiden name?</option>
                            <option>What was the make of your first car?</option>
                        </select>
                        <span asp-validation-for="SecurityQuestion" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="SecurityAnswer" class="form-label"></label>
                        <input asp-for="SecurityAnswer" class="form-control" autocomplete="off" />
                        <span asp-validation-for="SecurityAnswer" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Register</button>
                </form>
                <hr />
                <div class="text-center">
                    Already have an account? <a href="/Account/Login">Login</a>
                </div>
            </div>
        </div>
    </div>
</div>
