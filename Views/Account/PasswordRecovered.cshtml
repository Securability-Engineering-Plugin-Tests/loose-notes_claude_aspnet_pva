@model string
@{
    ViewData["Title"] = "Password Recovered";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-body p-4">
                <h2 class="card-title mb-3"><i class="bi bi-check-circle-fill text-success me-2"></i>Identity Verified</h2>
                <p class="text-muted">Your security question was answered correctly. Your current password is shown below.</p>
                <div class="alert alert-secondary font-monospace fs-5 text-center">@Model</div>
                <a href="/Account/Login" class="btn btn-primary w-100">Log In</a>
            </div>
        </div>
    </div>
</div>
