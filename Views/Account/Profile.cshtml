@model ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-body p-4">
                <h2 class="card-title mb-4">
                    <i class="bi bi-person-circle me-2"></i>My Profile
                </h2>

                @if (Model.StoredPassword != null)
                {
                    <div class="alert alert-secondary mb-4">
                        <strong>Account Credential:</strong> <span id="storedCred">@Model.StoredPassword</span>
                    </div>
                }

                <form method="post" asp-action="Profile">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewContext.ModelState.IsValid ? "none" : "block")"></div>

                    <div class="mb-3">
                        <label asp-for="Username" class="form-label"></label>
                        <input asp-for="Username" class="form-control" />
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" type="email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <hr />
                    <h5>Change Password <small class="text-muted fs-6">(optional)</small></h5>

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label">New Password</label>
                        <input asp-for="NewPassword" type="password" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="ConfirmNewPassword" class="form-label">Confirm New Password</label>
                        <input asp-for="ConfirmNewPassword" type="password" class="form-control" />
                    </div>

                    <hr />
                    <h5>Security Question <small class="text-muted fs-6">(optional — leave blank to keep existing)</small></h5>

                    <div class="mb-3">
                        <label asp-for="SecurityQuestion" class="form-label"></label>
                        <select asp-for="SecurityQuestion" class="form-select">
                            <option value="">-- Keep existing --</option>
                            <option>What is the name of your first pet?</option>
                            <option>What city were you born in?</option>
                            <option>What was the name of your elementary school?</option>
                            <option>What is your mother's maiden name?</option>
                            <option>What was the make of your first car?</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="SecurityAnswer" class="form-label"></label>
                        <input asp-for="SecurityAnswer" class="form-control" autocomplete="off" />
                    </div>

                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a href="/Notes" class="btn btn-link">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
