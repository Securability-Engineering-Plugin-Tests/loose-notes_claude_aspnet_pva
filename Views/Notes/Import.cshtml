@{
    ViewData["Title"] = "Import Notes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2 mb-0"><i class="bi bi-box-arrow-in-down me-2"></i>Import Notes</h1>
    <a href="/Notes/Export" class="btn btn-outline-secondary">
        <i class="bi bi-box-arrow-up me-1"></i>Export Instead
    </a>
</div>

<p class="text-muted">
    Upload a ZIP archive previously created by the Export feature. The archive must
    contain a <code>notes.json</code> manifest and, optionally, an
    <code>attachments/</code> folder with the associated files.
</p>

<form method="post" action="/Notes/Import" enctype="multipart/form-data" class="mb-4" style="max-width:480px">
    <div class="mb-3">
        <label for="zipFile" class="form-label fw-semibold">Archive File (.zip)</label>
        <input type="file" class="form-control" id="zipFile" name="zipFile" accept=".zip" required />
        <div class="form-text">Maximum upload size is determined by your server configuration.</div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-upload me-1"></i>Import
        </button>
        <a href="/Notes" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

<hr class="my-4" />

<h5 class="mb-3">Expected Archive Format</h5>
<pre class="bg-light border rounded p-3 small"><code>notes-export-20260402-120000.zip
├── notes.json
└── attachments/
    ├── 3_report.pdf
    └── 7_photo.png</code></pre>

<h6 class="mt-3 mb-2">notes.json schema</h6>
<pre class="bg-light border rounded p-3 small"><code>{
  "exportedAt": "2026-04-02T12:00:00Z",
  "version": "1.0",
  "notes": [
    {
      "title": "My Note",
      "content": "Note body text…",
      "isPublic": false,
      "createdAt": "2026-03-01T09:00:00Z",
      "updatedAt": "2026-03-15T14:30:00Z",
      "attachments": [
        {
          "fileName": "report.pdf",
          "zipPath": "attachments/3_report.pdf",
          "contentType": "application/pdf",
          "size": 204800
        }
      ]
    }
  ]
}</code></pre>
