@model List<Note>
@{
    ViewData["Title"] = "Search Notes";
    var query = ViewBag.Query as string ?? "";
}

<h1 class="h2 mb-4"><i class="bi bi-search me-2"></i>Search Notes</h1>

<div class="row mb-4">
    <div class="col-md-8">
        <form method="get" asp-action="Search" class="d-flex gap-2">
            <input type="text" name="q" value="@query" class="form-control" placeholder="Search notes by title or content..." autofocus />
            <button type="submit" class="btn btn-primary">Search</button>
        </form>
    </div>
</div>

@if (!string.IsNullOrEmpty(query))
{
    <p class="text-muted">
        @Model.Count result(s) for <strong>"@query"</strong>
    </p>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No notes found matching your search.</div>
    }
    else
    {
        <div class="list-group">
            @foreach (var note in Model)
            {
                <a href="/Notes/Details/@note.Id" class="list-group-item list-group-item-action">
                    <div class="d-flex w-100 justify-content-between align-items-center">
                        <div>
                            <strong>@note.Title</strong>
                            <small class="text-muted ms-2">by @note.Owner?.Username</small>
                            @if (note.IsPublic)
                            {
                                <span class="badge bg-success ms-2">Public</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary ms-2">Private</span>
                            }
                        </div>
                        @if (note.Ratings.Count > 0)
                        {
                            <span class="badge bg-warning text-dark">
                                <i class="bi bi-star-fill"></i> @note.AverageRating.ToString("F1")
                            </span>
                        }
                    </div>
                    <p class="mb-0 mt-1 text-muted small">
                        @(note.Content.Length > 200 ? note.Content.Substring(0, 200) + "..." : note.Content)
                    </p>
                </a>
            }
        </div>
    }
}
else
{
    <div class="alert alert-light">Enter a search term above to find notes.</div>
}
