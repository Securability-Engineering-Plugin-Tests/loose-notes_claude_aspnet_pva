@model List<Note>
@{
    ViewData["Title"] = "Export Notes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2 mb-0"><i class="bi bi-box-arrow-up me-2"></i>Export Notes</h1>
    <a href="/Notes/Import" class="btn btn-outline-secondary">
        <i class="bi bi-box-arrow-in-down me-1"></i>Import Instead
    </a>
</div>

<p class="text-muted">
    Select the notes you want to export. They will be packaged as a ZIP archive containing
    a <code>notes.json</code> manifest and any file attachments.
</p>

@if (!Model.Any())
{
    <div class="alert alert-info">
        You don't have any notes to export. <a href="/Notes/Create">Create your first note!</a>
    </div>
}
else
{
    <form method="post" action="/Notes/Export">
        <div class="card mb-3">
            <div class="card-header d-flex align-items-center gap-3">
                <div class="form-check mb-0">
                    <input class="form-check-input" type="checkbox" id="selectAll" />
                    <label class="form-check-label fw-semibold" for="selectAll">Select All</label>
                </div>
                <span class="text-muted small" id="selectionCount">0 of @Model.Count selected</span>
            </div>
            <div class="list-group list-group-flush">
                @foreach (var note in Model)
                {
                    <label class="list-group-item list-group-item-action d-flex align-items-start gap-3 py-3">
                        <div class="pt-1">
                            <input class="form-check-input note-checkbox" type="checkbox"
                                   name="selectedNoteIds" value="@note.Id" />
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <span class="fw-semibold">@note.Title</span>
                                @if (note.IsPublic)
                                {
                                    <span class="badge bg-success">Public</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Private</span>
                                }
                            </div>
                            <p class="mb-1 text-muted small">
                                @(note.Content.Length > 100 ? note.Content.Substring(0, 100) + "…" : note.Content)
                            </p>
                            <small class="text-muted">Updated @note.UpdatedAt.ToString("MMM d, yyyy")</small>
                        </div>
                    </label>
                }
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-download me-1"></i>Download ZIP
            </button>
            <a href="/Notes" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
}

@section Scripts {
<script>
    const selectAll = document.getElementById('selectAll');
    const checkboxes = document.querySelectorAll('.note-checkbox');
    const countLabel = document.getElementById('selectionCount');

    function updateCount() {
        const checked = document.querySelectorAll('.note-checkbox:checked').length;
        countLabel.textContent = checked + ' of @Model.Count selected';
        selectAll.indeterminate = checked > 0 && checked < checkboxes.length;
        selectAll.checked = checked === checkboxes.length && checkboxes.length > 0;
    }

    selectAll.addEventListener('change', () => {
        checkboxes.forEach(cb => cb.checked = selectAll.checked);
        updateCount();
    });

    checkboxes.forEach(cb => cb.addEventListener('change', updateCount));
    updateCount();
</script>
}
