@model Note
@{
    ViewData["Title"] = "Delete Note";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow border-danger">
            <div class="card-body p-4">
                <h2 class="card-title text-danger mb-3">
                    <i class="bi bi-exclamation-triangle me-2"></i>Delete Note
                </h2>
                <p>Are you sure you want to delete this note? This action cannot be undone.</p>

                <div class="bg-light p-3 rounded mb-4">
                    <strong>@Model.Title</strong>
                    <p class="text-muted small mt-1 mb-0">
                        @(Model.Content.Length > 200 ? Model.Content.Substring(0, 200) + "..." : Model.Content)
                    </p>
                </div>

                <div class="d-flex gap-3">
                    <form method="post" asp-action="Delete" asp-route-id="@Model.Id">
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash me-1"></i>Yes, Delete
                        </button>
                    </form>
                    <a href="/Notes/Details/@Model.Id" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</div>
