@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-5">
    <h1 class="display-4 text-danger">An Error Occurred</h1>
    <p class="lead">Something went wrong. Please try again.</p>
    @if (ViewBag.ErrorDetails != null)
    {
        <pre class="text-start bg-light p-3 rounded">@ViewBag.ErrorDetails</pre>
    }
    <a href="/" class="btn btn-primary mt-3">Go Home</a>
</div>
